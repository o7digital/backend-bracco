{
  "name": "@bracco/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "start:railway": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bracco/config": "workspace:*",
    "@bracco/types": "workspace:*",
    "cors": "2.8.6",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "morgan": "1.10.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "25.4.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}

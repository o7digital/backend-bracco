---
import { featuredWorkflows, workflowPlaybooks } from "../data/site";
import SectionHeading from "./SectionHeading.astro";

const workflowCards = featuredWorkflows.map((workflow) => {
  const approvedSteps = workflow.steps.filter((step) => step.status === "approved").length;
  const progress = Math.round((approvedSteps / workflow.steps.length) * 100);

  return {
    ...workflow,
    approvedSteps,
    progress,
  };
});

const statusClasses = {
  approved: "bg-emerald-50 text-emerald-700 border-emerald-200",
  awaiting_approval: "bg-amber-50 text-amber-700 border-amber-200",
  changes_requested: "bg-rose-50 text-rose-700 border-rose-200",
  in_review: "bg-bracco-mint/70 text-bracco-green border-bracco-line",
  draft: "bg-slate-50 text-slate-600 border-slate-200",
};
---

<section class="space-y-7" id="workflow-overview">
  <SectionHeading
    eyebrow="Workflow Overview"
    title="A single view of what is moving, blocked, or waiting for leadership."
    description="Each flow shows where the packet sits, who owns the next decision, and how much of the path has been cleared across the enterprise approval lane."
  />

  <div class="grid gap-6 xl:grid-cols-[1.45fr_0.95fr]">
    <div class="grid gap-6">
      {
        workflowCards.map((workflow) => (
          <article class="surface p-6">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="space-y-3">
                <div class="flex flex-wrap gap-2">
                  <span class="label-chip">{workflow.countryCode}</span>
                  <span class="label-chip">{workflow.language}</span>
                  <span class={`rounded-full border px-3 py-1 text-sm font-medium ${statusClasses[workflow.status]}`}>
                    {workflow.status.replaceAll("_", " ")}
                  </span>
                </div>
                <div>
                  <h3 class="text-2xl font-semibold tracking-tight text-bracco-ink">{workflow.title}</h3>
                  <p class="mt-2 max-w-3xl text-base leading-7 text-bracco-muted">{workflow.summary}</p>
                </div>
              </div>

              <div class="rounded-[22px] border border-bracco-line/80 bg-bracco-stone/70 px-4 py-3 text-sm text-bracco-muted">
                <p class="font-semibold text-bracco-ink">{workflow.requestedBy}</p>
                <p class="mt-1">Due {workflow.dueDate}</p>
              </div>
            </div>

            <div class="mt-6 space-y-3">
              <div class="flex items-center justify-between text-sm text-bracco-muted">
                <span>{workflow.approvedSteps} of {workflow.steps.length} departments cleared</span>
                <span>{workflow.progress}% complete</span>
              </div>
              <div class="h-2.5 rounded-full bg-bracco-mint/60">
                <div class="h-full rounded-full bg-bracco-green" style={`width: ${workflow.progress}%`}></div>
              </div>
            </div>

            <div class="mt-6 grid gap-3 md:grid-cols-2 xl:grid-cols-5">
              {
                workflow.steps.map((step) => (
                  <div class="rounded-[22px] border border-bracco-line/75 bg-white/75 p-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-bracco-muted">
                      {step.department.replaceAll("_", " ")}
                    </p>
                    <h4 class="mt-2 text-base font-semibold text-bracco-ink">{step.title}</h4>
                    <p class="mt-1 text-sm text-bracco-muted">{step.owner}</p>
                    <div class="mt-4 flex items-center justify-between text-sm">
                      <span class="text-bracco-muted">{step.slaHours}h SLA</span>
                      <span class="font-medium text-bracco-forest">{step.status.replaceAll("_", " ")}</span>
                    </div>
                  </div>
                ))
              }
            </div>
          </article>
        ))
      }
    </div>

    <aside class="surface p-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-bracco-green">Reusable playbooks</p>
          <h3 class="mt-2 text-2xl font-semibold tracking-tight text-bracco-ink">Repeatable operating patterns</h3>
        </div>
        <span class="rounded-full bg-bracco-mint px-3 py-2 text-sm font-medium text-bracco-green">3 active</span>
      </div>

      <div class="mt-6 space-y-4">
        {
          workflowPlaybooks.map((playbook) => (
            <article class="rounded-[24px] border border-bracco-line/80 bg-bracco-stone/70 p-5">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-bracco-green">
                {playbook.primaryDepartment.replaceAll("_", " ")}
              </p>
              <h4 class="mt-3 text-xl font-semibold tracking-tight text-bracco-ink">{playbook.name}</h4>
              <p class="mt-3 text-sm leading-6 text-bracco-muted">{playbook.description}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {playbook.markets.map((market) => <span class="label-chip">{market}</span>)}
              </div>
              <p class="mt-4 text-sm text-bracco-muted">Average cycle: {playbook.averageCycleDays} days</p>
            </article>
          ))
        }
      </div>
    </aside>
  </div>
</section>
